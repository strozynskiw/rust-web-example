# Database URL (SQLite by default — no setup needed)
DATABASE_URL=sqlite:./data.db

# For PostgreSQL (requires docker-compose up -d or external PostgreSQL):
# DATABASE_URL=postgresql://rustweb:rustweb@localhost:5432/rustweb

# Server port (default: 3000)
PORT=3000

# Log level (trace, debug, info, warn, error)
RUST_LOG=rust_web=debug,tower_http=debug
